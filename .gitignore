# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.staging

# ── Gmail OAuth client config + token stores (v2.0.1 — never commit) ───────────
.secrets/
.aiqa/
**/.aiqa/
*.gmail-token.json
client_secret*.json
gmail-token*.json
**/gmail/token.json
**/send_token.json
**/test_inbox_token.json

# ── Playwright auth state (Phase 4E — must never be committed) ────────────────
.auth/
storageState*.json
**/storageState.json
**/storageState*.json

# ── Phase 5G — Google auth storage state and runtime scripts (never committed) ─
**/15_google_auth/.auth/
**/15_google_auth/user-data-dir/
**/15_google_auth/*.cjs
**/google-storageState*.json
**/smoke_redacted*.png

# ── Phase 7C — Google OAuth storageState capture (snake_case variant, never committed) ─
storage_state_*.json
**/storage_state_*.json
**/google_oauth_smoke_screenshot.png
**/google_oauth_smoke_7c.cjs

# ── Python runtime ────────────────────────────────────────────────────────────
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/

# ── Node / Playwright ─────────────────────────────────────────────────────────
node_modules/
playwright-report/
test-results/
.playwright/

# ── OS noise ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Generated run outputs ─────────────────────────────────────────────────────
# Keep the outputs/ directory in git (for .gitkeep), exclude all run artifacts
outputs/*
!outputs/.gitkeep
outputs_dry/

# ── CI test reports (JUnit) ───────────────────────────────────────────────────
reports/

# ── Memory: runtime state (project runs, client data, learned patterns) ───────
# pricing_book.yaml is source — keep it. Everything else is runtime.
memory/projects/
memory/clients/
memory/patterns/
memory/snippets/
memory/lessons-learned/

# ── Real job/site input files (may contain client info) ───────────────────────
# Use sample_inputs/ for committed examples instead.
real_jobs/
real_sites/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/*.code-workspace
.idea/

# OpenAI tunnel-client binary (downloaded, not tracked)
tools/tunnel-client.exe
tools/tunnel-client*/

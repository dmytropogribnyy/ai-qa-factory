{
  "openapi": "3.0.0",
  "info": {
    "title": "Risky API Demo",
    "version": "1.0.0",
    "description": "AI QA Factory Phase 5M-R demo spec — intentionally risky endpoints for classification testing"
  },
  "servers": [
    { "url": "https://risky.example.com/api" }
  ],
  "paths": {
    "/users": {
      "get": {
        "operationId": "listUsers",
        "summary": "List users"
      }
    },
    "/users/{id}": {
      "get": {
        "operationId": "getUser",
        "summary": "Get user by ID"
      },
      "delete": {
        "operationId": "deleteUser",
        "summary": "Delete user"
      }
    },
    "/admin/users": {
      "delete": {
        "operationId": "adminDeleteUsers",
        "summary": "Admin: bulk delete users"
      }
    },
    "/admin/reports": {
      "get": {
        "operationId": "adminReports",
        "summary": "Admin reports"
      }
    },
    "/payments/charge": {
      "post": {
        "operationId": "chargePayment",
        "summary": "Charge a payment"
      }
    },
    "/payments/refund": {
      "post": {
        "operationId": "refundPayment",
        "summary": "Process refund"
      }
    },
    "/billing/history": {
      "get": {
        "operationId": "billingHistory",
        "summary": "Get billing history"
      }
    },
    "/account/deactivate": {
      "post": {
        "operationId": "deactivateAccount",
        "summary": "Deactivate account"
      }
    },
    "/orders": {
      "get": {
        "operationId": "listOrders",
        "summary": "List orders"
      },
      "post": {
        "operationId": "createOrder",
        "summary": "Create order"
      }
    },
    "/products": {
      "get": {
        "operationId": "listProducts",
        "summary": "List products"
      }
    }
  }
}

# AI QA Factory v3.2 — Autonomous AI QA Operator Pro — environment template.
# Never commit a real .env. Set only NAMES here; never paste secret values into the repo.
#
# The core deterministic lifecycle + CI run without any API key (mock mode never calls paid APIs).
# The bounded Claude Code worker uses the installed Claude Code CLI (its own auth), NOT these keys.

# --- LLM routing (for the QA-strategy/authoring helpers; the worker does NOT use these) ---
# Safe default: mock mode never calls paid APIs.
LLM_MODE=mock
MODEL_PROFILE=mock

# When ready for real LLM helper routing, use one of:
# MODEL_PROFILE=premium_hybrid   # latest hybrid routing
# MODEL_PROFILE=openai_only      # OpenAI only
# MODEL_PROFILE=anthropic_only   # Anthropic only
# MODEL_PROFILE=budget           # lower-cost routing

# --- Bounded Claude Code worker (client-work execution; operator-gated) ---
# The worker resolves the installed Claude Code CLI automatically. On Windows it prefers the native
# claude.exe over the npm .cmd/.ps1 wrappers (which corrupt the multi-line prompt). Override only if
# resolution fails, and only with the NATIVE executable path (never a .cmd/.bat/.ps1 wrapper):
# AIQA_CLAUDE_BIN=
# A live (paid) worker acceptance is operator-gated and must run in a clean, non-nested shell:
# AIQA_CLAUDE_LIVE=1
# AIQA_CLAUDE_MODEL=claude-haiku-4-5-20251001
# AIQA_CLAUDE_BUDGET=0.60

# --- Email identities — canonical policy: docs/EMAIL_IDENTITY_AND_MAILBOX_POLICY.md ---
# Two DISTINCT Gmail identities with two DISTINCT token stores and mutually-exclusive scopes:
# the send token can never read; the read token can never send. Names only, never values.
#
# (1) Gmail Scout SEND — dipptrue@gmail.com; scopes gmail.send + openid + email.
#     This is NOT a read-only inbox; it sends only after explicit per-message operator approval.
# GMAIL_OAUTH_CLIENT_JSON=
# GMAIL_OAUTH_TOKEN_JSON=
# GMAIL_EXPECTED_ACCOUNT=dipptrue@gmail.com
# GMAIL_FROM_EMAIL=dipptrue@gmail.com
# GMAIL_FROM_NAME=Dmytro Pogribnyy
# GMAIL_REPLY_TO=dipptrue@gmail.com
# AIQA_OPERATOR_EMAIL=dipptrue@gmail.com
# AIQA_NOTIFICATION_EMAIL=dipptrue@gmail.com
#
# (2) Gmail QA TEST INBOX — drdiplextech@gmail.com; scopes gmail.readonly + openid + email ONLY
#     (read-only; bounded correlated retrieval, never a generic mailbox reader). The client config
#     MAY reuse the same Desktop client; the token store MUST be a DISTINCT file from the send token.
# GMAIL_TEST_OAUTH_CLIENT_JSON=
# GMAIL_TEST_OAUTH_TOKEN_JSON=
# GMAIL_TEST_EXPECTED_ACCOUNT=drdiplextech@gmail.com
# AIQA_TEST_MAILBOX=drdiplextech@gmail.com
# AIQA_TEST_ALIAS_TEMPLATE=drdiplextech+{project_id}@gmail.com
#
# External send is DISABLED by default (kill switch); the operator clears it only for an approved
# action, then re-sets it:
# PROSPECT_RADAR_EXTERNAL_SEND_DISABLED=1

# API keys. Add only providers used by the selected MODEL_PROFILE.
# Never commit .env to Git.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional manual overrides. Leave commented if using MODEL_PROFILE.
# ARCHITECT_MODEL=gpt-5.5
# CODING_MODEL=anthropic/claude-sonnet-4-6
# REVIEW_MODEL=anthropic/claude-opus-4-7
# FAST_MODEL=anthropic/claude-sonnet-4-6
# VISION_MODEL=gpt-5.5
# FALLBACK_MODEL=gpt-5.4-mini

# Optional reasoning / adaptive effort per role.
# Defaults are profile-based:
# premium_hybrid: architect=high, coding=medium, review=xhigh, fast=low, vision=high, fallback=low
# ARCHITECT_EFFORT=high
# CODING_EFFORT=medium
# REVIEW_EFFORT=xhigh
# FAST_EFFORT=low
# VISION_EFFORT=high
# FALLBACK_EFFORT=low

# If a provider rejects optional effort params, the router retries safely without them.
ENABLE_EFFORT_PARAMS=true

# Windows: prevents UnicodeEncodeError when LLM responses contain non-ASCII chars.
# Uncomment (or set in shell) before running --require-real-llm on Windows.
# PYTHONUTF8=1

OUTPUT_DIR=outputs
MEMORY_DIR=memory
PERSISTENCE_BACKEND=json

LLM_TIMEOUT_SECONDS=90
LLM_MAX_RETRIES=2
